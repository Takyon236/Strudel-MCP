{
  "name": "strudel-mcp",
  "version": "0.2.0",
  "description": "Model Context Protocol server for the Strudel live-coding music language",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "strudel-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "author": "Takyon236",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Takyon236/Strudel-MCP.git"
  },
  "homepage": "https://github.com/Takyon236/Strudel-MCP#readme",
  "bugs": {
    "url": "https://github.com/Takyon236/Strudel-MCP/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "bun test tests",
    "test:unit": "bun test tests/encode.test.ts tests/validate.test.ts tests/theory.test.ts tests/library.test.ts tests/knowledge.test.ts",
    "test:tools": "bun test tests/tools.test.ts",
    "test:integration": "bun run build && bun test tests/integration.test.ts"
  },
  "keywords": [
    "mcp",
    "strudel",
    "tidalcycles",
    "livecoding",
    "music",
    "claude"
  ],
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
